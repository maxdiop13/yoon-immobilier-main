# ============================================================
# YOoN Immobilier — variables d'environnement
# Copier ce fichier en `.env.local` et renseigner les valeurs.
# Ne JAMAIS committer de secret réel.
# ============================================================

# URL canonique (metadata, OG, sitemap, JSON-LD).
# Tant que yoon.immo n'est pas branché : laisser sur l'URL Vercel publique.
# Quand yoon.immo est actif en prod : mettre "https://yoon.immo".
NEXT_PUBLIC_SITE_URL="https://yoon-immobilier.vercel.app"

# --- Hero « video-ready » ---
# Vide → le hero affiche le poster (rendu de façade). Renseigné → la vidéo se lance
# (autoplay, muet, en boucle). Respecte prefers-reduced-motion (poster fixe).
# Fournir des fichiers optimisés ; mp4 obligatoire, webm optionnel (meilleure compression).
NEXT_PUBLIC_HERO_VIDEO_SRC="/videos/hero-yoon.mp4"   # mp4 h264 (se lit partout, iOS/Safari compris)
NEXT_PUBLIC_HERO_VIDEO_WEBM=""                       # laissé vide : le mp4 suffit

# --- Coordonnées de conversion (À COMPLÉTER côté client) ---
# Numéro WhatsApp au format international SANS le "+" ni espaces (ex. 221770000000)
NEXT_PUBLIC_WHATSAPP_NUMBER=""
# Email de contact (défaut applicatif : contact@yoon.immo)
NEXT_PUBLIC_CONTACT_EMAIL="contact@yoon.immo"
# Lien de réservation d'appel découverte (Calendly / Cal.com / autre)
NEXT_PUBLIC_BOOKING_URL=""

# --- Endpoint de réception des formulaires (API route configurable) ---
# Webhook qui reçoit les soumissions (ex. Make, Zapier, n8n, Resend via fonction, CRM…).
# Si vide, l'API route renvoie une erreur explicite et les formulaires basculent
# sur un repli `mailto:` documenté dans le README.
FORM_WEBHOOK_URL=""
# Optionnel : clé partagée envoyée dans l'en-tête Authorization vers le webhook.
FORM_WEBHOOK_TOKEN=""

# --- Analytics (optionnel) ---
# Domaine Plausible (ex. yoon-immobilier.vercel.app). Si vide : aucun script tiers chargé.
# Les événements (lead_form_started, lead_form_submitted, guide_requested,
# diagnostic_completed, whatsapp_clicked, phone_clicked, partner_clicked) sont déjà
# poussés dans window.dataLayer dans tous les cas.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
